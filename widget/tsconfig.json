{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist/renderer",
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["src/renderer/**/*", "src/preload/**/*", "src/shared/**/*"]
}
