# unpdf@1.6.2's peerOptional @napi-rs/canvas range (^0.1.69) conflicts with
# the @napi-rs/canvas@1.0.2 this project actually needs (verified working
# with unpdf's renderPageAsImage via extensive manual testing). Without this,
# a from-scratch `npm install`/`npm ci` (as Vercel's build always does)
# hard-fails with ERESOLVE, even though the existing package-lock.json
# resolves fine incrementally in a dev environment with pre-existing
# node_modules.
legacy-peer-deps=true
